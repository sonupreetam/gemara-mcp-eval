# Container runtime: docker or podman
CONTAINER_RUNTIME=docker
GEMARA_MCP_IMAGE=ghcr.io/gemaraproj/gemara-mcp:v0.1.0
GEMARA_MCP_MODE=artifact

# Ollama (used by detllm, deepeval, mcpevals)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# LLM provider for promptfoo (optional)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
