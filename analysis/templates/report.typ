// Typst template for NFR6 compliance report PDF generation.
// Usage: typst compile report.typ --input data=../../results/nfr6-report.json

#let data = json(sys.inputs.at("data", default: "../../results/nfr6-report.json"))
#let nfr6 = data.nfr6_report

#set document(
  title: "NFR6 Determinism Compliance Report",
  author: "gemara-mcp-eval",
)

#set page(margin: 2.5cm)
#set text(font: "Inter", size: 11pt)

= NFR6 Determinism Compliance Report

#v(0.5em)

*Generated:* #nfr6.generated_at \
*Threshold:* #str(calc.round(nfr6.threshold * 100))% \
*Verdict:* #strong(nfr6.nfr6_verdict)

#v(1em)

== Summary

#let score_pct = str(calc.round(nfr6.overall_determinism_score * 100, digits: 1))

The overall determinism score across #nfr6.tools_evaluated of #nfr6.tools_total
evaluation tools is *#score_pct%*.

#if nfr6.nfr6_verdict == "PASS" [
  This meets the NFR6 requirement of #str(calc.round(nfr6.threshold * 100))%
  deterministic outcomes for artifact generation.
] else [
  This does *not* meet the NFR6 requirement of #str(calc.round(nfr6.threshold * 100))%
  deterministic outcomes. See per-tool breakdown for details.
]

#v(1em)

== Per-Tool Assessment

#table(
  columns: (auto, auto, auto, auto),
  [*Tool*], [*Available*], [*Score*], [*Status*],
  ..for a in data.per_tool_assessments {
    let score = if a.determinism_score != none {
      str(calc.round(a.determinism_score * 100, digits: 1)) + "%"
    } else {
      "N/A"
    }
    (a.tool, str(a.available), score, upper(a.nfr6_contribution))
  }
)

#v(1em)

== Evaluation Dimensions

#for (key, dim) in data.dimensions {
  [=== #dim.description]
  [Target: #str(calc.round(dim.target * 100))%]
  v(0.3em)
}

#v(2em)

#align(center)[
  _Report generated by gemara-mcp-eval — https://github.com/gemaraproj/gemara-mcp/issues/14_
]
